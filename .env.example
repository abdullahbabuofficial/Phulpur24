# Copy to .env.local and fill in real values.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_or_anon_jwt_xxx

# Optional: enables real LLM output in /admin/ai-writer.
# Without this the writer falls back to deterministic templates.
ANTHROPIC_API_KEY=sk-ant-xxx
