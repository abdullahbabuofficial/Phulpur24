# =============================================================================
# Phulpur24 — env template (committed to git, NEVER put real secrets here)
# -----------------------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and replace each
# "<...>" placeholder with the real value from Supabase / Anthropic.
# =============================================================================

# ---------- Supabase (public, safe in the browser) ---------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-supabase-anon-public-key>

# ---------- Supabase (server-only secrets, never expose to the browser) ------
# Service role key — bypasses Row-Level Security. Server code only.
SUPABASE_SERVICE_ROLE_KEY=<paste-supabase-service-role-key>

# JWT secret — used to verify Supabase tokens server-side if needed.
SUPABASE_JWT_SECRET=<paste-supabase-jwt-secret>

# Personal access token for the Supabase CLI (NOT used by the Next.js app).
SUPABASE_ACCESS_TOKEN=<paste-supabase-cli-personal-access-token>

# ---------- Anthropic (server-only) ------------------------------------------
# Powers /admin/ai-writer. If unset the AI Writer falls back to deterministic
# templates so the UI still works.
ANTHROPIC_API_KEY=<paste-anthropic-api-key>

# ---------- Deployment toggles -----------------------------------------------
# Set to "1" on the public-site deployment (e.g. phulpur24.com) so /admin/*
# and /api/ai/* return a hard 404. Leave unset for local dev and the admin
# subdomain deployment (e.g. admin.phulpur24.com).
# PUBLIC_SITE_HIDE_ADMIN=1

# Dev-only escape hatch: when "1" AND not a production build, allows the
# legacy demo password fallback. Leave unset for any real environment.
# NEXT_PUBLIC_ADMIN_ALLOW_DEMO=1
